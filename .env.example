# Скопируй в .env и заполни значения
# cp .env.example .env

# JWT — одинаковый для всех сервисов (обязательно поменяй в проде!)
JWT_SECRET=nTDmGYqtvLfDCptgzwG+xKGtXV/JHL4fHKJrxK9tHdI=

# Сроки жизни токенов (мс). 604800000 = 7 дней, 86400000 = 1 день
JWT_EXPIRATION=604800000
JWT_REFRESH_EXPIRATION=86400000

# Пароль для всех PostgreSQL баз
DB_USERNAME=user
DB_PASSWORD=change_me_in_production

# Dadata API токен (нужен только gateway, можно оставить пустым)
IP_LOCATION_API_TOKEN=
